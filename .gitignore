# ═══════════════════════════════════════════════════════════════
# SENTINELS v2.0 — Security-Hardened .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── Secrets & Credentials (CRITICAL) ─────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
*.truststore
kubeconfig*
*kubeconfig*
secrets/
credentials/
*.secret
service-account*.json
gcloud-key*.json
*.credentials

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
pip-log.txt
pip-delete-this-directory.txt

# ─── ML Models & Data ───────────────────────────────────────
*.pkl
*.joblib
*.h5
*.hdf5
*.onnx
*.pt
*.pth
*.safetensors
model_weights/
evaluation_results.jsonl

# ─── Node.js ────────────────────────────────────────────────
node_modules/
.next/
dist/
build/
*.tsbuildinfo
.turbo/
.vercel/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── IDE & Editor ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# ─── Docker ─────────────────────────────────────────────────
.docker/
*.tar
docker-data/
postgres_data/

# ─── Kubernetes ─────────────────────────────────────────────
*.kubeconfig
helm-charts/**/charts/
*.tgz

# ─── Logs ───────────────────────────────────────────────────
*.log
logs/
*.log.*
*.log.gz

# ─── Database ───────────────────────────────────────────────
*.db
*.sqlite3
*.sqlite
*.sql.bak
dump.sql
*.dump

# ─── Temporary & Cache ──────────────────────────────────────
tmp/
temp/
scratch/
.cache/
*.tmp
*.bak
*.orig

# ─── Test & Coverage ────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/

# ─── Terraform (if used later) ──────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example

# ─── Trace & Debug ──────────────────────────────────────────
trace.json
trace.json.gz
*.heapsnapshot
*.cpuprofile