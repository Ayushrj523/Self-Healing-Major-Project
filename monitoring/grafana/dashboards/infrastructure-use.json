{
  "annotations": { "list": [] },
  "description": "Infrastructure USE Method Dashboard (Utilization, Saturation, Errors)",
  "editable": true,
  "panels": [
    {
      "title": "CPU Utilization by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"netflix|prime|sentinels-system\"}[5m])) by (pod) / sum(container_spec_cpu_quota{namespace=~\"netflix|prime|sentinels-system\"}/container_spec_cpu_period{namespace=~\"netflix|prime|sentinels-system\"}) by (pod) * 100",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "title": "Memory Utilization by Pod",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"netflix|prime|sentinels-system\"}) by (pod) / sum(container_spec_memory_limit_bytes{namespace=~\"netflix|prime|sentinels-system\"}) by (pod) * 100",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "title": "Network I/O (Bytes/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total{namespace=~\"netflix|prime\"}[5m])) by (pod)", "legendFormat": "RX: {{pod}}" },
        { "expr": "sum(rate(container_network_transmit_bytes_total{namespace=~\"netflix|prime\"}[5m])) by (pod)", "legendFormat": "TX: {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "Pod Restarts",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"netflix|prime|sentinels-system\"}) by (pod)", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(rate(container_fs_reads_bytes_total{namespace=~\"netflix|prime\"}[5m])) by (pod)", "legendFormat": "Read: {{pod}}" },
        { "expr": "sum(rate(container_fs_writes_bytes_total{namespace=~\"netflix|prime\"}[5m])) by (pod)", "legendFormat": "Write: {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "use", "sentinels"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Infrastructure USE Metrics",
  "uid": "sentinels-infra-use"
}
